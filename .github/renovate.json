{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigests",
    "group:docusaurusMonorepo",
    "group:definitelyTyped"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "automerge": true,
      "description": "Automerge minor and patch updates for devDependencies if CI passes.",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "automerge": true,
      "description": "Automerge minor and patch updates for GitHub Actions.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "automerge": true,
      "description": "Automerge lock file maintenance.",
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ]
    },
    {
      "automerge": false,
      "description": "Group Node.js runtime updates (.node-version, engines, and packageManager)",
      "groupName": "node and yarn runtime",
      "matchDepTypes": [
        "engines",
        "packageManager",
        "required-node"
      ],
      "matchManagers": [
        "nvm",
        "npm"
      ],
      "matchPackageNames": [
        "node",
        "yarn"
      ]
    },
    {
      "description": "Group common linting/formatting tools.",
      "groupName": "linters and formatters",
      "matchPackageNames": [
        "prettier",
        "eslint",
        "@typescript-eslint/{/,}**",
        "eslint-{/,}**"
      ]
    },
    {
      "description": "Group React and React-DOM together to prevent mismatches.",
      "groupName": "react packages",
      "matchPackageNames": [
        "react",
        "react-dom"
      ]
    },
    {
      "description": "Minimum release age for NPM packages.",
      "matchDatasources": [
        "npm"
      ],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Minimum release age for GitHub Actions.",
      "matchManagers": [
        "github-actions"
      ],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Version pinning, GitHub Actions: Skip for Azure (Microsoft), Cloudflare, GitHub owned actions.",
      "groupName": "official github actions",
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": false,
      "separateMajorMinor": false,
      "matchPackageNames": [
        "actions/{/,}**",
        "azure/{/,}**",
        "cloudflare/{/,}**"
      ]
    }
  ],
  "schedule": [
    "on Friday",
    "every weekend"
  ],
  "semanticCommits": "enabled",
  "timezone": "Europe/Oslo"
}
